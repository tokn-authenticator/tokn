<?xml version="1.0" encoding="utf-8"?>
<!--
   Tokn stores OTP secrets locally. Cloud backup is disabled via
   android:allowBackup="false", but data_extraction_rules also governs
   Android 12+ device-to-device (D2D) transfers regardless of allowBackup.
   Exclude everything explicitly so secrets never leave the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
